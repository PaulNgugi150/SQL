--1ST WAY OF HANDLING DUPLICATES
DROP VIEW PN_DECODE_DEMO_COPY;
CREATE OR REPLACE TABLE PN_DECODE_DEMO_COPY AS 
SELECT DISTINCT * FROM PN_DECODE_DEMO;
SELECT DISTINCT * FROM PN_DECODE_DEMO_COPY;

SELECT DISTINCT SNAME,COUNT(*)
FROM PN_DECODE_DEMO_COPY
GROUP BY SNAME
HAVING COUNT(*) > 1
ORDER BY SNAME;

